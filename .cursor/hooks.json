{
  "version": 1,
  "hooks": {
    "preToolUse": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/guard-contract.ps1",
        "matcher": "Write|StrReplace",
        "timeout": 10
      }
    ],
    "sessionStart": [
      {
        "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/check-trunk-sync.ps1",
        "timeout": 8
      }
    ]
  }
}
